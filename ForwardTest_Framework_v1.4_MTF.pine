//@version=6
strategy("Forward-Test Framework v1.4 MTF", overlay=true, initial_capital=5000, currency=currency.GBP, calc_on_every_tick=false, process_orders_on_close=false, commission_type=strategy.commission.percent, commission_value=0.015, slippage=1)
// Same HONEST rig + MTF confirmation stack (run on 1-MINUTE chart).
// BASE CAPITAL LOCKED: £5,000 GBP starting equity, everywhere. Never changes.
// Keeps v1.3's min stop-distance floor that caps commission drag.

grp_risk     = "Risk & Position Sizing"
accountEquity= input.float(5000.0, "Account Size (£) — LOCKED BASE", group=grp_risk)
riskPct      = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, group=grp_risk) / 100
rrRatio      = input.float(2.0, "Risk to Reward Ratio", minval=0.5, step=0.1, group=grp_risk)
atrLen       = input.int(14, "ATR Lookback Period", group=grp_risk)
atrMult      = input.float(1.5, "ATR Stop Multiplier", group=grp_risk)
minStopDist  = input.float(20.0, "Min Stop Distance (£) — caps 1m over-sizing", minval=0.0, step=1.0, group=grp_risk)
minQtyStep   = input.float(0.01, "Min Lot / Qty Step (live rounding)", minval=0.000001, group=grp_risk)

grp_sig      = "Signal — MTF Confirmation Stack"
tfExecFast   = input.int(20, "1m Trigger Fast EMA", group=grp_sig)
tfExecSlow   = input.int(50, "1m Trigger Slow EMA", group=grp_sig)
htfFast      = input.int(20, "HTF Confirm Fast EMA", group=grp_sig)
htfSlow      = input.int(50, "HTF Confirm Slow EMA", group=grp_sig)
tf5          = input.timeframe("5",  "Confirm TF 1", group=grp_sig)
tf15         = input.timeframe("15", "Confirm TF 2", group=grp_sig)
tf60         = input.timeframe("60", "Confirm TF 3", group=grp_sig)
useErGate    = input.bool(true, "Efficiency-Ratio chop gate", group=grp_sig)
erLen        = input.int(14, "Efficiency Ratio Lookback", group=grp_sig)
erMin        = input.float(0.30, "Min Efficiency Ratio", minval=0.0, maxval=1.0, step=0.05, group=grp_sig)
cooldownBars = input.int(10, "Min bars between entries (cooldown)", minval=0, group=grp_sig)

grp_time     = "Forward Test Window"
useDateFilter= input.bool(true, "Enable Forward Test Date Lock", group=grp_time)
startDate    = input.time(timestamp("2026-01-01 00:00"), "Forward Test Start", group=grp_time)

inForwardTest = not useDateFilter or (time >= startDate)

atrVal    = ta.atr(atrLen)
stopDist  = math.max(atrVal * atrMult, minStopDist)
riskAmount = accountEquity * riskPct
float qtyRaw  = (not na(stopDist) and stopDist > 0) ? riskAmount / stopDist : na
float qtySize = na(qtyRaw) ? na : math.max(minQtyStep, math.floor(qtyRaw / minQtyStep) * minQtyStep)
bool  riskOK  = inForwardTest and not na(qtySize) and qtySize > 0

float commDragPct = stopDist > 0 ? (0.00015 * 2 * close / stopDist) * 100 : na

htfTrend() =>
    ta.ema(close, htfFast) > ta.ema(close, htfSlow) ? 1 : -1

int dir5  = request.security(syminfo.tickerid, tf5,  htfTrend()[1], lookahead=barmerge.lookahead_off)
int dir15 = request.security(syminfo.tickerid, tf15, htfTrend()[1], lookahead=barmerge.lookahead_off)
int dir60 = request.security(syminfo.tickerid, tf60, htfTrend()[1], lookahead=barmerge.lookahead_off)

bool stackLong  = dir5 == 1  and dir15 == 1  and dir60 == 1
bool stackShort = dir5 == -1 and dir15 == -1 and dir60 == -1

fastEMA = ta.ema(close, tfExecFast)
slowEMA = ta.ema(close, tfExecSlow)
bool trigLong  = ta.crossover(fastEMA, slowEMA)
bool trigShort = ta.crossunder(fastEMA, slowEMA)

float erChange = math.abs(close - close[erLen])
float erVol    = math.sum(math.abs(close - close[1]), erLen)
float effRatio = erVol > 0 ? erChange / erVol : 0.0
bool  trending = not useErGate or effRatio >= erMin

var int lastEntryBar = na
bool cooledDown = na(lastEntryBar) or (bar_index - lastEntryBar) >= cooldownBars

bool longCondition  = trigLong  and stackLong  and trending and cooledDown
bool shortCondition = trigShort and stackShort and trending and cooledDown

var float longStop  = na
var float longTP    = na
var float shortStop = na
var float shortTP   = na

if (longCondition and riskOK and strategy.position_size == 0)
    longStop := close - stopDist
    longTP   := close + (stopDist * rrRatio)
    strategy.entry("Long", strategy.long, qty=qtySize)
    strategy.exit("Exit Long", "Long", stop=longStop, limit=longTP)
    lastEntryBar := bar_index

if (shortCondition and riskOK and strategy.position_size == 0)
    shortStop := close + stopDist
    shortTP   := close - (stopDist * rrRatio)
    strategy.entry("Short", strategy.short, qty=qtySize)
    strategy.exit("Exit Short", "Short", stop=shortStop, limit=shortTP)
    lastEntryBar := bar_index

plot(fastEMA, color=color.blue,   title="1m Fast EMA")
plot(slowEMA, color=color.orange, title="1m Slow EMA")

f_arrow(d) => d == 1 ? "UP" : d == -1 ? "DN" : "--"
float winRate = strategy.closedtrades > 0 ? 100.0 * strategy.wintrades / strategy.closedtrades : 0.0
float profFac = strategy.grossloss > 0 ? strategy.grossprofit / strategy.grossloss : na

var table dash = table.new(position=position.top_right, columns=2, rows=12, bgcolor=color.new(color.black, 20), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "Base Capital (£)", text_color=color.white, bgcolor=color.gray)
    table.cell(dash, 1, 0, str.tostring(accountEquity, "#"), text_color=color.white, bgcolor=color.gray)
    table.cell(dash, 0, 1, "Forward Test Mode", text_color=color.white)
    table.cell(dash, 1, 1, inForwardTest ? "ACTIVE" : "INACTIVE", text_color=color.white, bgcolor=inForwardTest ? color.green : color.red)
    table.cell(dash, 0, 2, "5m trend",  text_color=color.white)
    table.cell(dash, 1, 2, f_arrow(dir5),  text_color=dir5 == 1 ? color.green : color.red)
    table.cell(dash, 0, 3, "15m trend", text_color=color.white)
    table.cell(dash, 1, 3, f_arrow(dir15), text_color=dir15 == 1 ? color.green : color.red)
    table.cell(dash, 0, 4, "1h trend",  text_color=color.white)
    table.cell(dash, 1, 4, f_arrow(dir60), text_color=dir60 == 1 ? color.green : color.red)
    table.cell(dash, 0, 5, "Efficiency Ratio", text_color=color.white)
    table.cell(dash, 1, 5, str.tostring(effRatio, "#.##"), text_color=trending ? color.green : color.red)
    table.cell(dash, 0, 6, "Stop Distance (£)", text_color=color.white)
    table.cell(dash, 1, 6, str.tostring(stopDist, "#.##"), text_color=color.white)
    table.cell(dash, 0, 7, "Comm drag (% of risk)", text_color=color.white)
    table.cell(dash, 1, 7, na(commDragPct) ? "—" : str.tostring(commDragPct, "#.#") + "%", text_color=commDragPct <= 10 ? color.green : color.red)
    table.cell(dash, 0, 8, "Position Size", text_color=color.white)
    table.cell(dash, 1, 8, na(qtySize) ? "—" : str.tostring(qtySize, "#.####"), text_color=color.white)
    table.cell(dash, 0, 9, "Win %", text_color=color.white)
    table.cell(dash, 1, 9, str.tostring(winRate, "#.#") + "%", text_color=color.white)
    table.cell(dash, 0, 10, "Profit Factor", text_color=color.white)
    table.cell(dash, 1, 10, na(profFac) ? "—" : str.tostring(profFac, "#.##"), text_color=profFac >= 1.0 ? color.green : color.red)
    table.cell(dash, 0, 11, "Net P&L (£)", text_color=color.white)
    table.cell(dash, 1, 11, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.green : color.red)
