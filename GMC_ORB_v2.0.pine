//@version=6
strategy("GMC ORB v2.0", overlay=true, initial_capital=5000, currency=currency.GBP, calc_on_every_tick=false, process_orders_on_close=false, commission_type=strategy.commission.percent, commission_value=0.015, slippage=1)
// NEW HYPOTHESIS: Opening-Range Breakout (momentum off a session level), NOT a
// crossover. Same honest rig: £5k GBP lock, 1% risk, ATR stop+floor, real
// commission, next-bar fills. Only the ENTRY changed. Run on 5m or 15m chart.

grp_risk     = "Risk & Position Sizing"
accountEquity= input.float(5000.0, "Account Size (£) — LOCKED BASE", group=grp_risk)
riskPct      = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, group=grp_risk) / 100
rrRatio      = input.float(2.0, "Risk to Reward Ratio", minval=0.5, step=0.1, group=grp_risk)
atrLen       = input.int(14, "ATR Lookback Period", group=grp_risk)
atrMult      = input.float(1.5, "ATR Stop Multiplier", group=grp_risk)
minStopDist  = input.float(20.0, "Min Stop Distance (£) — caps over-sizing", minval=0.0, step=1.0, group=grp_risk)
minQtyStep   = input.float(0.01, "Min Lot / Qty Step (live rounding)", minval=0.000001, group=grp_risk)

grp_sig      = "Opening-Range Breakout"
orSess       = input.session("1300-1400", "Opening-Range window (builds the range)", group=grp_sig)
tradeSess    = input.session("1400-2000", "Trade window (breakouts allowed)", group=grp_sig)
tz           = input.string("GMT+0", "Session timezone", group=grp_sig)
oneWait      = input.bool(true, "Only one long + one short per day", group=grp_sig)

grp_time     = "Forward Test Window"
useDateFilter= input.bool(false, "Enable Forward Test Date Lock", group=grp_time)
startDate    = input.time(timestamp("2026-01-01 00:00"), "Forward Test Start", group=grp_time)

inForwardTest = not useDateFilter or (time >= startDate)

atrVal    = ta.atr(atrLen)
stopDist  = math.max(atrVal * atrMult, minStopDist)
riskAmount = accountEquity * riskPct
float qtyRaw  = (not na(stopDist) and stopDist > 0) ? riskAmount / stopDist : na
float qtySize = na(qtyRaw) ? na : math.max(minQtyStep, math.floor(qtyRaw / minQtyStep) * minQtyStep)
bool  riskOK  = inForwardTest and not na(qtySize) and qtySize > 0
float commDragPct = stopDist > 0 ? (0.00015 * 2 * close / stopDist) * 100 : na

bool inOR    = not na(time(timeframe.period, orSess, tz))
bool inTrade = not na(time(timeframe.period, tradeSess, tz))
bool newDay  = ta.change(time("D")) != 0

var float orH = na
var float orL = na
var bool  tookLong  = false
var bool  tookShort = false
if newDay
    orH := na
    orL := na
    tookLong  := false
    tookShort := false
if inOR
    orH := na(orH) ? high : math.max(orH, high)
    orL := na(orL) ? low  : math.min(orL, low)

bool orReady = not na(orH) and not na(orL)
bool longBreak  = orReady and inTrade and not inOR and ta.crossover(close, orH)  and (not oneWait or not tookLong)
bool shortBreak = orReady and inTrade and not inOR and ta.crossunder(close, orL) and (not oneWait or not tookShort)

var float longStop = na
var float longTP   = na
var float shortStop= na
var float shortTP  = na

if (longBreak and riskOK and strategy.position_size == 0)
    longStop := close - stopDist
    longTP   := close + (stopDist * rrRatio)
    strategy.entry("Long", strategy.long, qty=qtySize)
    strategy.exit("Exit Long", "Long", stop=longStop, limit=longTP)
    tookLong := true

if (shortBreak and riskOK and strategy.position_size == 0)
    shortStop := close + stopDist
    shortTP   := close - (stopDist * rrRatio)
    strategy.entry("Short", strategy.short, qty=qtySize)
    strategy.exit("Exit Short", "Short", stop=shortStop, limit=shortTP)
    tookShort := true

plot(orReady ? orH : na, color=color.green, style=plot.style_linebr, title="OR High")
plot(orReady ? orL : na, color=color.red,   style=plot.style_linebr, title="OR Low")
bgcolor(inOR ? color.new(color.blue, 90) : na)

float winRate = strategy.closedtrades > 0 ? 100.0 * strategy.wintrades / strategy.closedtrades : 0.0
float profFac = strategy.grossloss > 0 ? strategy.grossprofit / strategy.grossloss : na

var table dash = table.new(position=position.top_right, columns=2, rows=11, bgcolor=color.new(color.black, 20), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "Base Capital (£)", text_color=color.white, bgcolor=color.gray)
    table.cell(dash, 1, 0, str.tostring(accountEquity, "#"), text_color=color.white, bgcolor=color.gray)
    table.cell(dash, 0, 1, "In OR window", text_color=color.white)
    table.cell(dash, 1, 1, inOR ? "YES" : "no", text_color=inOR ? color.green : color.gray)
    table.cell(dash, 0, 2, "In trade window", text_color=color.white)
    table.cell(dash, 1, 2, inTrade ? "YES" : "no", text_color=inTrade ? color.green : color.gray)
    table.cell(dash, 0, 3, "OR High", text_color=color.white)
    table.cell(dash, 1, 3, na(orH) ? "—" : str.tostring(orH, "#.##"), text_color=color.white)
    table.cell(dash, 0, 4, "OR Low", text_color=color.white)
    table.cell(dash, 1, 4, na(orL) ? "—" : str.tostring(orL, "#.##"), text_color=color.white)
    table.cell(dash, 0, 5, "Stop Distance (£)", text_color=color.white)
    table.cell(dash, 1, 5, str.tostring(stopDist, "#.##"), text_color=color.white)
    table.cell(dash, 0, 6, "Comm drag (% of risk)", text_color=color.white)
    table.cell(dash, 1, 6, na(commDragPct) ? "—" : str.tostring(commDragPct, "#.#") + "%", text_color=commDragPct <= 10 ? color.green : color.red)
    table.cell(dash, 0, 7, "Closed Trades", text_color=color.white)
    table.cell(dash, 1, 7, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(dash, 0, 8, "Win %", text_color=color.white)
    table.cell(dash, 1, 8, str.tostring(winRate, "#.#") + "%", text_color=color.white)
    table.cell(dash, 0, 9, "Profit Factor", text_color=color.white)
    table.cell(dash, 1, 9, na(profFac) ? "—" : str.tostring(profFac, "#.##"), text_color=profFac >= 1.0 ? color.green : color.red)
    table.cell(dash, 0, 10, "Net P&L (£)", text_color=color.white)
    table.cell(dash, 1, 10, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.green : color.red)
